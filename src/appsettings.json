{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "Urls": "http://*:5005",
  "AppSettings": {
    "InjectSpecificationDocument": false
  },
  "Telegram": {
    "DefaultApiId": 0,
    "DefaultApiHash": "",
    "SessionsPath": "session"
  },
  "Auth": {
    "AdminUsername": "admin",
    "AdminPassword": "__CHANGE_ME__",
    "CookieName": "telegrammonitor_admin",
    "CookieExpireMinutes": 480,
    "SlidingExpiration": true
  },
  "DbConnection": {
    "DbType": "Sqlite", 
    "ConnectionString": "DataSource=telegrammonitor.db"
  },
  "Bot": {
    "Enabled": false,
    "Tokens": []
  },
  "AllowedHosts": "*"
}
